{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Elph settings configuration schema",
	"type": "object",
	"properties": {
		"models": {
			"type": "object",
			"properties": {
				"lastSync": { "type": "string" },
				"syncInterval": { "type": "string" }
			}
		},
		"showThinking": {
			"type": "boolean",
			"description": "Stream and display model reasoning in the chat. Default true.",
			"default": true
		},
		"autoExpandThinking": {
			"type": "boolean",
			"description": "Start thinking blocks expanded in the chat. Default false.",
			"default": false
		},
		"session": {
			"type": "object",
			"properties": {
				"providerId": {
					"type": "string",
					"description": "Last selected provider id from ~/.elph/providers."
				},
				"modelId": {
					"type": "string",
					"description": "Last selected model id for the active provider."
				},
				"agentMode": {
					"type": "string",
					"enum": ["build", "plan", "ask", "brave"],
					"description": "Active agent mode. Default build.",
					"default": "build"
				},
				"thinkingLevel": {
					"type": "string",
					"enum": ["off", "minimal", "low", "medium", "high", "xhigh"],
					"description": "Active thinking level shown in the footer. Default high.",
					"default": "high"
				}
			}
		}
	}
}